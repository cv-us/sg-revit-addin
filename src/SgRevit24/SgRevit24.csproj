<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <RootNamespace>SgRevitAddin</RootNamespace>
    <AssemblyName>SgRevit24</AssemblyName>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <DefineConstants>REVIT2024</DefineConstants>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <!-- Shared source files -->
  <ItemGroup>
    <Compile Include="..\Shared\**\*.cs" LinkBase="Shared" />
  </ItemGroup>

  <!-- Revit API references - update paths to match your Revit installation -->
  <ItemGroup>
    <Reference Include="RevitAPI">
      <HintPath>C:\Program Files\Autodesk\Revit 2024\RevitAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="RevitAPIUI">
      <HintPath>C:\Program Files\Autodesk\Revit 2024\RevitAPIUI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- AdWindows.dll exposes the underlying WPF ribbon (Autodesk.Windows
         namespace) — not part of the public Revit API but ships with every
         Revit install. We use it for ribbon-tab styling that Revit's public
         API can't reach (the colored underline beneath our tab). -->
    <Reference Include="AdWindows">
      <HintPath>C:\Program Files\Autodesk\Revit 2024\AdWindows.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="System.Xaml" />
  </ItemGroup>

  <!-- NuGet packages needed for .NET Framework 4.8 -->
  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.*" />
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <!-- Embedded icon resources -->
  <ItemGroup>
    <EmbeddedResource Include="..\Shared\UI\Resources\icons\*.png" LinkBase="Icons" />
  </ItemGroup>

  <!-- Config files -->
  <ItemGroup>
    <None Include="..\Shared\Config\defaults.json" Link="Config\defaults.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="SgRevit24.addin">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>

