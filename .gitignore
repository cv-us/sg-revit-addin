# Revit temp/backup files
*.slog
*.0001.rvt
*.0002.rvt
*.0003.rvt
*.rvt.bak
*.rfa.bak

# Installer build output (compiled .exe lands here)
installer/Output/*
!installer/Output/.gitkeep

# Revit families bundled into the installer (large binary files, kept out of git)
installer/Families/**/*.rfa
installer/Families/**/*.rfa.bak

# Claude Code session/worktree state — do not commit
.claude/

